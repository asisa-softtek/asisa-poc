{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/pokemon/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/pokemon/sitemap",
      "destination": "/api/sitemap"
    },
    {
      "source": "/pokemon/:name",
      "destination": "/api/pokemon?name=:name"
    }
  ]
}
